        {
          "type": "frame",
          "id": "qgd71",
          "name": "aBody",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 40,
          "padding": [
            64,
            240
          ],
          "children": [
            {
              "type": "text",
              "id": "xAMhh",
              "fill": "$text-primary",
              "content": "Our Mission",
              "fontFamily": "Outfit",
              "fontSize": 28,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "CuERI",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Our cooperative was founded on the belief that housing should be affordable, sustainable, and community-driven. Since 2005, we have grown from a small group of like-minded individuals into a thriving community of over 150 members who share a vision of collaborative living.",
              "lineHeight": 1.7,
              "fontFamily": "Outfit",
              "fontSize": 16,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "d3Us0",
              "fill": "$text-primary",
              "content": "Our Values",
              "fontFamily": "Outfit",
              "fontSize": 28,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "ABIKB",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Transparency, sustainability, and community engagement are at the heart of everything we do. Our elected board of directors works diligently to ensure that every decision reflects the collective interests of our members. We believe in open governance, responsible stewardship, and fostering connections between neighbors.",
              "lineHeight": 1.7,
              "fontFamily": "Outfit",
              "fontSize": 16,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "s7Fb2",
              "fill": "$text-primary",
              "content": "Our History",
              "fontFamily": "Outfit",
              "fontSize": 28,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "3o4Fc",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Established in downtown Toronto, our cooperative has been a model of urban community living for nearly two decades. What began as a renovation of a single building has expanded into a full-service residential community with modern amenities, professional management, and a strong sense of belonging.",
              "lineHeight": 1.7,
              "fontFamily": "Outfit",
              "fontSize": 16,
              "fontWeight": "normal"
            }
          ]
        },
