@startuml c4-context

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

skinparam defaultFontSize 11
skinparam shadowing false

title Event Sourcing and Audit Trail - C4 Context Diagram

Person(user, "Cooperative User", "Member, staff, or admin who triggers domain events via platform actions")
Person(auditor, "Auditor / Admin", "Reviews historical events and audit trail via StoredEvent API")

System(coop, "Coop Platform", "Cooperative housing management platform with event sourcing and real-time event streaming")

System_Ext(publicApp, "Public Web App", "Can subscribe to member-facing event streams when needed")
System_Ext(adminApp, "Admin Backend", "Subscribes to operational and audit-related updates")

Rel(user, coop, "Performs actions that generate domain events")
Rel(auditor, adminApp, "Uses")
Rel(publicApp, coop, "Subscribes to event streams", "SSE / HTTPS")
Rel(adminApp, coop, "Queries stored events and subscribes to event streams", "HTTPS / SSE")

@enduml
