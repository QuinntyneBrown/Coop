@startuml c4-container

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title Theme and Content Customization - C4 Container Diagram

Person(admin, "Administrator", "Manages themes and CMS content")

System_Boundary(coop, "Coop Platform") {
    Container(publicApp, "Public Web App", "Web application", "Renders themed public pages and CMS-managed content")
    Container(adminApp, "Admin Backend", "Web application", "Authors themes and content")
    Container(api, "Coop API", ".NET / ASP.NET Core", "Shared modular monolith API with Theme and JsonContent endpoints")
    ContainerDb(db, "Coop Database", "SQL Server", "Themes and JsonContents tables")
}

Rel(admin, adminApp, "Configures themes and content", "HTTPS")
Rel(adminApp, api, "REST calls", "HTTPS/JSON")
Rel(publicApp, api, "Reads themes and content", "HTTPS/JSON")
Rel(api, db, "Reads/Writes", "EF Core")

@enduml
