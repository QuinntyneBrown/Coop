@startuml c4-context

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title Theme and Content Customization - C4 Context Diagram

Person(admin, "Administrator", "Manages platform themes and CMS content")
Person(member, "Member / Visitor", "Views themed public pages and dynamic content")

System(coop, "Theme and CMS Modules", "Customization capabilities within the Coop modular monolith")

System_Ext(publicApp, "Public Web App", "Applies themes and renders CMS-driven content")
System_Ext(adminApp, "Admin Backend", "Authors themes and content")

Rel(admin, adminApp, "Uses")
Rel(member, publicApp, "Uses")
Rel(adminApp, coop, "Creates and updates themes and JSON content", "HTTPS/JSON")
Rel(publicApp, coop, "Fetches themes and JSON content", "HTTPS/JSON")

@enduml
