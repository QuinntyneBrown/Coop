@startuml
skinparam dpi 150
skinparam pageMargin 10
skinparam sequenceMessageAlign center
skinparam defaultFontSize 10

title Upload Digital Asset

actor Client
participant "DigitalAssetController" as Ctrl
participant "MediatR" as Med
participant "UploadDigitalAssetHandler" as Handler
participant "IHttpContextAccessor" as Ctx
participant "MultipartReader" as Reader
database "ICoopDbContext" as DB

Client -> Ctrl : POST /api/DigitalAsset/upload\n(multipart/form-data)
activate Ctrl

Ctrl -> Med : Send(UploadDigitalAssetRequest)
activate Med

Med -> Handler : Handle(request)
activate Handler

Handler -> Ctx : HttpContext.Request
Handler -> Reader : ReadNextSectionAsync()
activate Reader

loop each file section
  Reader --> Handler : section (bytes, name, contentType)
  Handler -> Handler : Read bytes into MemoryStream
  Handler -> DB : Find existing by name\nor create new DigitalAsset
  alt is image
    Handler -> Handler : Extract Height, Width\nvia System.Drawing.Image
  end
end

Reader --> Handler : null (no more sections)
deactivate Reader

Handler -> DB : SaveChangesAsync()
DB --> Handler : saved

Handler --> Med : UploadDigitalAssetResponse\n{DigitalAssetIds}
deactivate Handler

Med --> Ctrl : response
deactivate Med

Ctrl --> Client : 200 OK {DigitalAssetIds}
deactivate Ctrl

@enduml
