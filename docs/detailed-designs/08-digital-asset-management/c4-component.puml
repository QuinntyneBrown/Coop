@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

skinparam dpi 150
skinparam pageMargin 10

title C4 Component -- Digital Asset Management (API Layer)

Container_Boundary(api, "Coop API / Asset Microservice") {
  Component(ctrl, "DigitalAssetController", "ASP.NET Controller", "Routes: upload, get by ID,\nbatch get, serve, delete")

  Component(uploadHandler, "UploadDigitalAssetHandler", "MediatR Handler", "Parses multipart body,\nextracts image dimensions,\npersists assets")

  Component(getByIdHandler, "GetDigitalAssetByIdHandler", "MediatR Handler", "Retrieves single asset\nby DigitalAssetId")

  Component(batchHandler, "GetDigitalAssetsByIdsHandler", "MediatR Handler", "Retrieves assets matching\nan array of IDs")

  Component(pageHandler, "GetDigitalAssetsPageHandler", "MediatR Handler", "Paginated asset listing")

  Component(removeHandler, "RemoveDigitalAssetHandler", "MediatR Handler", "Deletes asset record")

  Component(dto, "DigitalAssetDto", "DTO", "Projection of DigitalAsset\nfor API responses")

  Component(ext, "DigitalAssetExtensions", "Extension Methods", "ToDto() mapping")
}

ContainerDb(db, "SQL Database", "EF Core", "DigitalAssets table")
Container(bus, "Message Bus", "RabbitMQ", "Integration events")

Rel(ctrl, uploadHandler, "Sends command")
Rel(ctrl, getByIdHandler, "Sends query")
Rel(ctrl, batchHandler, "Sends query")
Rel(ctrl, pageHandler, "Sends query")
Rel(ctrl, removeHandler, "Sends command")

Rel(uploadHandler, db, "Insert / Update")
Rel(getByIdHandler, db, "Select by ID")
Rel(batchHandler, db, "Select by IDs")
Rel(pageHandler, db, "Select page")
Rel(removeHandler, db, "Delete")
Rel(removeHandler, bus, "Publish\nDigitalAssetDeletedEvent")

Rel(uploadHandler, ext, "Uses ToDto()")
Rel(getByIdHandler, ext, "Uses ToDto()")
Rel(batchHandler, ext, "Uses ToDto()")

@enduml
