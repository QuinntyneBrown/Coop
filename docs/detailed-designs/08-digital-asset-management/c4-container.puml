@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

skinparam dpi 150
skinparam pageMargin 10

title C4 Container -- Digital Asset Management

Person(user, "Coop User", "Uploads and manages assets")

System_Boundary(coop, "Coop Platform") {
  Container(publicApp, "Public Web App", "Web application", "Displays published media and served assets")
  Container(adminApp, "Admin Backend", "Web application", "File upload UI, avatar management, document media selection")
  Container(api, "Coop API", ".NET / ASP.NET Core", "DigitalAssetController and application handlers")
  ContainerDb(db, "SQL Database", "SQL Server / EF Core", "DigitalAssets table with binary content and metadata")
}

Rel(user, adminApp, "Uploads files and manages assets")
Rel(adminApp, api, "REST API calls", "HTTPS")
Rel(publicApp, api, "Reads and serves published assets", "HTTPS")
Rel(api, db, "Read/Write assets", "EF Core")

@enduml
