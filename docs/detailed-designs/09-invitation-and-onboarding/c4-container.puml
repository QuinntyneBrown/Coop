@startuml c4-container

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title Invitation and Onboarding - C4 Container Diagram

Person(admin, "Administrator", "Manages invitations")
Person(invitee, "Invitee", "Redeems invitation token")

System_Boundary(coop, "Coop Platform") {
    Container(publicApp, "Public Web App", "Angular 21 application", "Onboarding and invitation redemption")
    Container(adminApp, "Admin Backend", "Angular 21 application", "Invitation management and operational administration")
    Container(api, "Coop API", ".NET 10 / ASP.NET Core", "Shared modular monolith API")
    ContainerDb(db, "SQL Database", "SQL Server / EF Core", "Stores invitation tokens, users, and profiles")
}

admin -down-> adminApp : Manages tokens
invitee -down-> publicApp : Enters invitation token

adminApp -down-> api : REST calls
publicApp -down-> api : REST calls
api -down-> db : Reads / writes tokens

@enduml
