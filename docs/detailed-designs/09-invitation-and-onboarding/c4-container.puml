@startuml c4-container

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title Invitation and Onboarding - C4 Container Diagram

Person(admin, "Administrator", "Manages invitations")
Person(invitee, "Invitee", "Redeems invitation token")

System_Boundary(coop, "Coop Platform") {
    Container(spa, "SPA Frontend", "Angular", "Onboarding UI and\nadmin invitation management")
    Container(api, "Coop API", ".NET / ASP.NET Core", "Monolith REST API with\nMediatR CQRS handlers")
    Container(profileSvc, "Profile Service", ".NET / ASP.NET Core", "Microservice managing\nprofiles and invitation tokens")
    ContainerDb(db, "SQL Database", "SQL Server / EF Core", "Stores invitation tokens,\nusers, and profiles")
}

admin -down-> spa : Manages tokens
invitee -down-> spa : Enters invitation token

spa -down-> api : REST calls\n(monolith path)
spa -down-> profileSvc : REST calls\n(microservice path)

api -down-> db : Reads / writes tokens
profileSvc -down-> db : Reads / writes tokens

@enduml
