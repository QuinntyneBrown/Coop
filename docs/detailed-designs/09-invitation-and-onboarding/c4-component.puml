@startuml c4-component

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title Invitation and Onboarding - C4 Component Diagram

Person(client, "Client", "Administrator or invitee")

Container_Boundary(api, "Coop API") {
    Component(ctrl, "InvitationTokenController", "ASP.NET Controller", "CRUD, validate, and consume-token endpoints")
    Component(mediator, "IMediator", "MediatR", "Routes commands and queries")
    Component(createH, "CreateInvitationTokenHandler", "RequestHandler", "Creates and persists new tokens")
    Component(getH, "GetInvitationTokenHandler", "RequestHandler", "Retrieves tokens by ID or page")
    Component(updateH, "UpdateInvitationTokenExpiryHandler", "RequestHandler", "Updates token expiry")
    Component(removeH, "RemoveInvitationTokenHandler", "RequestHandler", "Deletes a token")
    Component(validateH, "ValidateAndConsumeInvitationHandler", "RequestHandler", "Validates token state and coordinates onboarding")
    Component(provisioning, "OnboardingProvisioningService", "Application Service", "Creates user and profile records in-process")
}

ContainerDb(db, "Database", "SQL Server", "InvitationTokens, Users, Profiles")

client -down-> ctrl : HTTP requests
ctrl -down-> mediator : Send
mediator -down-> createH
mediator -down-> getH
mediator -down-> updateH
mediator -down-> removeH
mediator -down-> validateH

validateH -right-> provisioning : Provision account\nand profile

createH -down-> db : Insert
getH -down-> db : Select
updateH -down-> db : Update
removeH -down-> db : Delete
validateH -down-> db : Query / Update

@enduml
