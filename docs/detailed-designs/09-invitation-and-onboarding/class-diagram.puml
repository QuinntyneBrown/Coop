@startuml class-diagram

skinparam classAttributeIconSize 0
skinparam defaultFontSize 11
skinparam classFontSize 13
skinparam classAttributeFontSize 10
skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam pageMargin 10

title Invitation and Onboarding - Class Diagram

package "Invitation Domain" {

    class InvitationToken <<Entity>> {
        + InvitationTokenId : Guid
        + Value : string
        + Type : InvitationTokenType
        + ExpiryDate : DateTime?
        + IsUsed : bool
        + CreatedAt : DateTime
        --
        + InvitationToken(value, type, expiryDate?)
        + UpdateExpiry(expiryDate : DateTime?) : void
        + MarkAsUsed() : void
        + IsValid() : bool
    }

    enum InvitationTokenType {
        Member
        BoardMember
        OnCall
        Staff
    }
}

package "Domain Events" {

    class ValidateInvitationToken <<DomainEvent>> {
        + InvitationToken : string
    }

    class ValidatedInvitationToken <<DomainEvent>> {
        + IsValid : bool
        + InvitationTokenType : string
    }
}

package "Application Layer" {

    class InvitationTokenDto {
        + InvitationTokenId : Guid
        + Value : string
        + Expiry : DateTime?
    }

    class InvitationProvisioningHandler {
        - _context : ICoopDbContext
        - _provisioningService : OnboardingProvisioningService
        --
        + Handle(ValidateInvitationToken, ct) : Task
    }
}

InvitationToken --> InvitationTokenType : uses
InvitationProvisioningHandler ..> ValidateInvitationToken : handles
InvitationProvisioningHandler ..> ValidatedInvitationToken : returns
InvitationProvisioningHandler ..> InvitationToken : queries

@enduml
