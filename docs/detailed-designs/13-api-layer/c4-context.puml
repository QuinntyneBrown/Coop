@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Coop Platform -- C4 System Context Diagram

Person(member, "Co-op Member", "Uses member-facing cooperative features")
Person(staff, "Staff / Board Member", "Operates the cooperative and publishes content")
Person(admin, "System Administrator", "Configures users, privileges, themes, and CMS content")

System(publicApp, "Public Web App", "CMS-driven public-facing application")
System(adminApp, "Admin Backend", "Operational and editorial back-office application")
System(coop, "Coop Backend API", "ASP.NET Core modular monolith API")

System_Ext(email, "Email Service", "Sends invitation and notification emails")

Rel(member, publicApp, "Uses", "HTTPS")
Rel(staff, adminApp, "Uses", "HTTPS")
Rel(admin, adminApp, "Uses", "HTTPS")
Rel(publicApp, coop, "Calls API", "HTTPS/JSON")
Rel(adminApp, coop, "Calls API", "HTTPS/JSON")
Rel(coop, email, "Sends emails", "SMTP")

@enduml
