@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Coop Platform -- C4 System Context Diagram

Person(member, "Co-op Member", "Submits maintenance requests,\nviews documents and notices")
Person(staff, "Staff / Board Member", "Manages requests, publishes\ncontent, administers users")
Person(admin, "System Administrator", "Configures roles, privileges,\nand themes")

System(coop, "Coop Platform", "ASP.NET Core REST API\nfor cooperative management")

System_Ext(email, "Email Service", "Sends invitation and\nnotification emails")
System_Ext(spa, "SPA Client", "Angular/React front-end\napplication")

Rel(member, coop, "Uses", "HTTPS/JSON")
Rel(staff, coop, "Manages", "HTTPS/JSON")
Rel(admin, coop, "Administers", "HTTPS/JSON")
Rel(spa, coop, "Calls API", "HTTPS/JSON")
Rel(coop, email, "Sends emails", "SMTP")

@enduml
