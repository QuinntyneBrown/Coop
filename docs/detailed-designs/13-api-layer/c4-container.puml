@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Coop Platform -- C4 Container Diagram

Person(user, "User", "Co-op member, staff, board member, or administrator")

System_Boundary(coop, "Coop Platform") {
  Container(publicApp, "Public Web App", "Angular 21 application", "CMS-driven public experience")
  Container(adminApp, "Admin Backend", "Angular 21 application", "Operations and content administration")
  Container(api, "Coop API", ".NET 10 / ASP.NET Core", "REST API host, middleware, Swagger, JWT auth")
  Container(app, "Application Layer", ".NET 10 Class Library", "MediatR handlers, validators, commands, queries")
  Container(domain, "Domain Layer", ".NET 10 Class Library", "Domain entities, aggregates, interfaces, domain events")
  Container(infra, "Infrastructure Layer", ".NET 10 Class Library", "EF Core DbContext, persistence, auth helpers")
  ContainerDb(db, "SQL Server", "Database", "Stores users, profiles, requests, documents, content, events")
}

Rel(user, publicApp, "Uses when interacting with member/public features", "HTTPS")
Rel(user, adminApp, "Uses when performing operational or editorial work", "HTTPS")
Rel(publicApp, api, "Calls", "HTTPS/JSON")
Rel(adminApp, api, "Calls", "HTTPS/JSON")
Rel(api, app, "Dispatches via", "IMediator")
Rel(app, domain, "References", "Entities/Interfaces")
Rel(app, infra, "Uses", "ICoopDbContext")
Rel(infra, db, "Reads/Writes", "EF Core / SQL")

@enduml
