@startuml c4-context

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

skinparam defaultFontSize 11
skinparam shadowing false
skinparam pageMargin 10

title Modular Monolith Architecture - C4 Context Diagram

Person(member, "Cooperative Member", "Uses public and member-facing features")
Person(staff, "Staff Member", "Operates workflows and publishes content")
Person(admin, "Admin", "Manages users, roles, content, and settings")

System(publicApp, "Public Web App", "CMS-driven public-facing application")
System(adminApp, "Admin Backend", "Operational and editorial back-office application")
System(coopBackend, "Coop Backend", "Modular monolith API and application runtime")

Rel(member, publicApp, "Uses", "HTTPS")
Rel(staff, adminApp, "Uses", "HTTPS")
Rel(admin, adminApp, "Uses", "HTTPS")

Rel(publicApp, coopBackend, "Calls API", "HTTPS/JSON")
Rel(adminApp, coopBackend, "Calls API", "HTTPS/JSON")

@enduml
