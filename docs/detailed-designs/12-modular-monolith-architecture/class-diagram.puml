@startuml class-diagram

skinparam defaultFontSize 10
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam packageFontSize 11
skinparam linetype ortho
skinparam nodesep 40
skinparam ranksep 30
skinparam pageMargin 10
skinparam wrapWidth 200

title Modular Monolith Architecture - Class Diagram

package "Core Runtime" {
  abstract class DomainEvent {
    +EventId : Guid
    +CreatedAt : DateTime
    +CorrelationId : string?
  }

  interface "IDomainEventHandler<TEvent>" as IHandler {
    +HandleAsync(event: TEvent, ct: CancellationToken) : Task
  }

  class DomainEventDispatcher {
    +DispatchAsync(event, ct) : Task
  }

  class CoopDbContext {
  }
}

package "Application Surfaces" {
  class PublicWebApp
  class AdminBackend
}

package "Application Modules" {
  class IdentityModule
  class ProfileModule
  class MaintenanceModule
  class DocumentModule
  class AssetModule
  class MessagingModule
  class CmsModule
}

package "Query Services" {
  class PublicContentQueryService
  class AdminOperationsQueryService
}

DomainEventDispatcher ..> DomainEvent : dispatches
IHandler ..> DomainEvent : handles
DomainEventDispatcher --> IHandler : invokes

IdentityModule --> CoopDbContext
ProfileModule --> CoopDbContext
MaintenanceModule --> CoopDbContext
DocumentModule --> CoopDbContext
AssetModule --> CoopDbContext
MessagingModule --> CoopDbContext
CmsModule --> CoopDbContext

PublicWebApp --> PublicContentQueryService
AdminBackend --> AdminOperationsQueryService
PublicContentQueryService --> CoopDbContext
AdminOperationsQueryService --> CoopDbContext

@enduml
