@startuml c4-container

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

skinparam defaultFontSize 10
skinparam shadowing false
skinparam pageMargin 10

title Modular Monolith Architecture - C4 Container Diagram

Person(user, "User", "Member, staff, board member, or admin")

System_Boundary(platform, "Coop Platform") {
  Container(publicApp, "Public Web App", "Web application", "CMS-driven public site and member-facing journeys")
  Container(adminApp, "Admin Backend", "Web application", "Operations, content management, and administration")
  Container(api, "Coop API", "ASP.NET Core", "Shared REST API surface")
  Container(modules, "Application Modules", ".NET Class Libraries", "Identity, Profile, Maintenance, Document, Asset, Messaging, CMS")
  Container(dispatcher, "Domain Event Dispatcher", ".NET Service", "Dispatches in-process notifications")
  ContainerDb(db, "Coop Database", "SQL Server", "Shared database with module-owned tables or schemas")
}

Rel(user, publicApp, "Uses", "HTTPS")
Rel(user, adminApp, "Uses", "HTTPS")
Rel(publicApp, api, "Calls", "HTTPS/JSON")
Rel(adminApp, api, "Calls", "HTTPS/JSON")
Rel(api, modules, "Dispatches to", "MediatR / application services")
Rel(modules, dispatcher, "Raises domain events")
Rel(modules, db, "Reads/Writes", "EF Core")

@enduml
