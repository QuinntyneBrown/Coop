@startuml sequence-publish-event

skinparam defaultFontSize 11
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam pageMargin 10

title Dispatch In-Process Domain Event

participant "Application Service" as Service
participant "DomainEventDispatcher" as Dispatcher
participant "DomainEvent" as Event
participant "Handler" as Handler
participant "Read Model / Audit" as Projection

Service -> Event ** : new DomainEvent()
Service -> Dispatcher : DispatchAsync(event)
activate Dispatcher

Dispatcher -> Handler : HandleAsync(event)
activate Handler
Handler -> Projection : Update projection / audit
activate Projection
Projection --> Handler : complete
deactivate Projection
Handler --> Dispatcher : complete
deactivate Handler

Dispatcher --> Service : complete
deactivate Dispatcher

@enduml
