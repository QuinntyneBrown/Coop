@startuml c4-component

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

skinparam defaultFontSize 10
skinparam shadowing false
skinparam pageMargin 10

title Modular Monolith Architecture - C4 Component Diagram

Container_Boundary(backend, "Coop Backend") {
  Component(publicEndpoints, "Public API Endpoints", "Controllers", "Public content, onboarding, member-facing read endpoints")
  Component(adminEndpoints, "Admin API Endpoints", "Controllers", "Operational, editorial, and administrative endpoints")
  Component(appModules, "Application Modules", "Application Services", "Identity, Profile, Maintenance, Document, Asset, Messaging, CMS")
  Component(dispatcher, "DomainEventDispatcher", "Service", "Dispatches in-process domain notifications")
  Component(readModels, "Read Models / Projections", "Queries", "Shapes data for public and admin clients")
  Component(dbContext, "CoopDbContext", "EF Core DbContext", "Persists module-owned data")
}

Rel(publicEndpoints, appModules, "Uses")
Rel(adminEndpoints, appModules, "Uses")
Rel(appModules, dispatcher, "Raises events")
Rel(dispatcher, readModels, "Triggers updates")
Rel(appModules, dbContext, "Reads/Writes")
Rel(readModels, dbContext, "Queries")

@enduml
