@startuml sequence-subscribe-event

skinparam defaultFontSize 11
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam pageMargin 10

title Subscribe and Handle Integration Event

participant "Redis\nPub/Sub" as Redis
participant "IMessageBus\n(RedisMessageBus)" as Bus
participant "IMessageSerializer\n(MessagePack)" as Serializer
participant "IIntegrationEvent\nHandler<TEvent>" as Handler
participant "Service\n(e.g. Messaging)" as Service

== Startup: Register Subscription ==

Service -> Bus : SubscribeAsync<TEvent>(handler)
activate Bus
Bus -> Bus : GetChannelName<TEvent>()
Bus -> Redis : SubscribeAsync("{prefix}:{channel}")
activate Redis
Redis --> Bus : subscription active
deactivate Redis
deactivate Bus

== Runtime: Event Arrives ==

Redis -> Bus : OnMessage(channel, byte[] data)
activate Bus

Bus -> Serializer : Deserialize<MessageEnvelope>(data)
activate Serializer
return envelope

Bus -> Serializer : Deserialize<TEvent>(envelope.Payload)
activate Serializer
return @event

Bus -> Handler : handler(@event)
activate Handler

Handler -> Service : process domain logic
activate Service
Service --> Handler : done
deactivate Service

Handler --> Bus : Task complete
deactivate Handler

Bus -> Bus : Log: "Handled event {EventType}"
deactivate Bus

@enduml
