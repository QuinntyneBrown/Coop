@startuml sequence-subscribe-event

skinparam defaultFontSize 11
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam pageMargin 10

title Register and Handle In-Process Domain Event

participant "Application Startup" as Startup
participant "DomainEventDispatcher" as Dispatcher
participant "Handler Registry" as Registry
participant "Module Handler" as Handler
participant "Owning Module" as Module

== Startup ==

Startup -> Registry : Register handler for DomainEvent
Registry --> Startup : registered

== Runtime ==

Module -> Dispatcher : DispatchAsync(domainEvent)
activate Dispatcher
Dispatcher -> Registry : Resolve handlers
Registry --> Dispatcher : matching handlers
Dispatcher -> Handler : HandleAsync(domainEvent)
activate Handler
Handler -> Module : apply side effect
Module --> Handler : complete
deactivate Handler
Dispatcher --> Module : complete
deactivate Dispatcher

@enduml
