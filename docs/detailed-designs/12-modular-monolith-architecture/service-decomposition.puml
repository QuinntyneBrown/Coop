@startuml service-decomposition

skinparam defaultFontSize 10
skinparam shadowing false
skinparam packageFontSize 12
skinparam packageStyle rectangle
skinparam pageMargin 10
skinparam nodesep 20
skinparam ranksep 20

title Modular Monolith Architecture - Module Decomposition

package "Application Surfaces" as apps #LightGray {
  [Public Web App] as publicApp
  [Admin Backend] as adminApp
}

package "Identity Module" as identity #LightBlue {
  [User] as user
  [Role] as role
  [Privilege] as privilege
  user --> role
  role --> privilege
}

package "Profile Module" as profile #LightGreen {
  [ProfileBase] as profileBase
  [Member] as member
  [BoardMember] as boardMember
  [StaffMember] as staffMember
  [InvitationToken] as invite
  member -u-|> profileBase
  boardMember -u-|> profileBase
  staffMember -u-|> profileBase
  profileBase ..> invite
}

package "Maintenance Module" as maintenance #LightYellow {
  [MaintenanceRequest] as mRequest
  [Comment] as comment
  [Attachment\n(reference)] as mAsset
  mRequest --> comment
  mRequest --> mAsset
}

package "Document Module" as document #LightCoral {
  [DocumentBase] as docBase
  [ByLaw] as bylaw
  [Notice] as notice
  [Report] as report
  bylaw -u-|> docBase
  notice -u-|> docBase
  report -u-|> docBase
}

package "Asset Module" as asset #Wheat {
  [DigitalAsset] as digitalAsset
  [Theme] as theme
}

package "Messaging Module" as messaging #Thistle {
  [Conversation] as conversation
  [Message] as message
  conversation --> message
}

package "CMS Module" as cms #WhiteSmoke {
  [JsonContent] as jsonContent
  [Named Sections] as sections
  jsonContent --> sections
}

package "Shared Runtime" as runtime #MintCream {
  [Coop API] as api
  [Domain Event\nDispatcher] as dispatcher
  [Shared Database] as db
}

publicApp ..> api : calls
adminApp ..> api : calls

api ..> identity : uses
api ..> profile : uses
api ..> maintenance : uses
api ..> document : uses
api ..> asset : uses
api ..> messaging : uses
api ..> cms : uses

identity ..> dispatcher : raises events
profile ..> dispatcher : raises events
maintenance ..> dispatcher : raises events
document ..> dispatcher : raises events
asset ..> dispatcher : raises events
messaging ..> dispatcher : raises events
cms ..> dispatcher : raises events

identity --> db
profile --> db
maintenance --> db
document --> db
asset --> db
messaging --> db
cms --> db

@enduml
