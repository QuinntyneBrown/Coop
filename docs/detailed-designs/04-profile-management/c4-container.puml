@startuml c4-container

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title Profile Management - C4 Container Diagram

Person(user, "User", "Cooperative member, board member, staff, or admin")

System_Boundary(profileBoundary, "Coop Backend - Profile Management") {
    Container(profileApi, "Profile API", ".NET 10 / ASP.NET Core", "REST endpoints for profile CRUD, avatar management, and type-specific operations")
    Container(profileApp, "Profile Application", ".NET 10 Class Library", "Commands, queries, and internal coordination with Identity and Asset modules")
    Container(profileDomain, "Profile Domain", ".NET 10 Class Library", "ProfileBase, Member, BoardMember, StaffMember, OnCall, Address")
    Container(profileInfra, "Profile Persistence", ".NET 10 Class Library", "EF Core DbContext and entity configurations")
    ContainerDb(profileDb, "Coop Database", "SQL Server", "Profiles, invitations, and related module-owned tables")
}

System_Ext(identityModule, "Identity & Access Module", "Owns users and profile-selection state")
System_Ext(assetModule, "Asset Module", "Stores digital assets")

Rel(user, profileApi, "HTTPS/JSON", "REST API calls")
Rel(profileApi, profileApp, "Uses")
Rel(profileApp, profileDomain, "Uses")
Rel(profileApp, profileInfra, "Uses")
Rel(profileInfra, profileDb, "Reads/Writes", "EF Core")
Rel(profileApp, identityModule, "Coordinates profile ownership", "Internal contract")
Rel(profileApp, assetModule, "Resolves avatar assets", "Internal contract")

@enduml
