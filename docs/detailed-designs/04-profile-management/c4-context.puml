@startuml c4-context

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title Profile Management - C4 Context Diagram

Person(resident, "Cooperative Resident", "Member, board member, or staff of the cooperative")
Person(admin, "System Administrator", "Manages profiles and user assignments")

System(profileModule, "Profile Management Module", "Manages profile CRUD, avatar association, and profile-type-specific attributes")

System_Ext(identityModule, "Identity & Access Module", "User accounts, authentication, and current/default profile ownership")
System_Ext(assetModule, "Asset Module", "Stores and serves digital assets such as avatar images")

Rel(resident, profileModule, "Views and updates own profiles", "HTTPS/JSON")
Rel(admin, profileModule, "Creates and manages all profiles", "HTTPS/JSON")
Rel(profileModule, identityModule, "Updates current/default profile state", "Internal application contract")
Rel(profileModule, assetModule, "References avatar DigitalAssetId", "Internal application contract")

@enduml
