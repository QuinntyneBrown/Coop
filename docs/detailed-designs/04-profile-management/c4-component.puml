@startuml c4-component

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title Profile Management - C4 Component Diagram

Container_Boundary(profileApi, "Profile API") {
    Component(profilesCtrl, "ProfilesController", "ASP.NET Core Controller (.NET 10)", "Get profiles, set avatar, delete profile")
    Component(boardCtrl, "BoardMembersController", "ASP.NET Core Controller (.NET 10)", "CRUD for board member profiles")
    Component(membersCtrl, "MembersController", "ASP.NET Core Controller (.NET 10)", "CRUD for member profiles")
    Component(staffCtrl, "StaffMembersController", "ASP.NET Core Controller (.NET 10)", "CRUD for staff member profiles")
    Component(onCallCtrl, "OnCallController", "ASP.NET Core Controller (.NET 10)", "CRUD for on-call profiles")
    Component(profileAppSvc, "ProfileApplicationService", "Application Service", "Coordinates profile creation, updates, and user-profile defaults")
    Component(dbContext, "ProfileDbContext", "EF Core DbContext", "Persists profiles and invitations")
}

ContainerDb(db, "Coop Database", "SQL Server", "Profiles and related tables")
System_Ext(identityModule, "Identity & Access Module", "Updates current/default profile state")
System_Ext(assetModule, "Asset Module", "Supplies avatar assets")

Rel(profilesCtrl, profileAppSvc, "Uses")
Rel(boardCtrl, profileAppSvc, "Uses")
Rel(membersCtrl, profileAppSvc, "Uses")
Rel(staffCtrl, profileAppSvc, "Uses")
Rel(onCallCtrl, profileAppSvc, "Uses")
Rel(profileAppSvc, dbContext, "Queries/Updates profiles")
Rel(dbContext, db, "EF Core", "SQL")
Rel(profileAppSvc, identityModule, "Updates user-profile links", "Internal contract")
Rel(profileAppSvc, assetModule, "Validates avatar references", "Internal contract")

@enduml
