@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

skinparam dpi 150
skinparam defaultFontSize 10

title C4 Context -- Role & Privilege Management

Person(admin, "System Administrator", "Manages roles, privileges, and user assignments")
Person(user, "Coop User", "Member, staff, or board member using the platform")

System(coop, "Coop Platform", "Co-operative management system with RBAC authorization")
System_Ext(adminApp, "Admin Backend", "Administrative interface for RBAC management")
System_Ext(publicApp, "Public Web App", "Consumes privilege-aware member-facing features")

Rel(admin, adminApp, "Manages roles & privileges via")
Rel(user, publicApp, "Accesses platform features via")
Rel(adminApp, coop, "REST API calls", "HTTPS/JSON")
Rel(publicApp, coop, "REST API calls", "HTTPS/JSON")
Rel(coop, coop, "Enforces access via privilege claims in JWT")

@enduml
