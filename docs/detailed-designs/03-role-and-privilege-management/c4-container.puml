@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

skinparam dpi 150
skinparam defaultFontSize 10

title C4 Container -- Role & Privilege Management

Person(admin, "Administrator", "Manages roles and privileges")

System_Boundary(coop, "Coop Platform") {
  Container(adminApp, "Admin Backend", "Angular 21 application", "Role and privilege management UI")
  Container(api, "Coop API", ".NET 10 / ASP.NET Core", "REST controllers: RoleController, PrivilegeController, UserController")
  Container(app, "Application Layer", "MediatR Handlers", "CQRS command/query handlers for roles and privileges")
  Container(domain, "Domain Layer", "C# Domain Model", "Role, Privilege, User entities; AccessRight enum; authorization rules")
  ContainerDb(db, "SQL Database", "EF Core", "Roles, Privileges, Users tables with join table")
}

Rel(admin, adminApp, "Uses", "HTTPS")
Rel(adminApp, api, "REST API", "JSON/HTTPS")
Rel(api, app, "MediatR.Send()")
Rel(app, domain, "Domain entities & logic")
Rel(app, db, "EF Core read/write")
Rel(api, domain, "Authorization check", "Privilege evaluation")

@enduml
