@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

skinparam dpi 150
skinparam pageMargin 10

title Document Management - C4 Context Diagram

Person(boardMember, "Board Member", "Creates and publishes by-laws, notices, and reports")
Person(staffMember, "Staff Member", "Manages documents on behalf of the co-op")
Person(member, "Member / Visitor", "Views published documents")

System(docSystem, "Document Management Module", "Manages creation, publishing, and retrieval of cooperative documents")

System_Ext(adminApp, "Admin Backend", "Authoring and publication workflows")
System_Ext(publicApp, "Public Web App", "Renders published content")
System_Ext(assetModule, "Asset Module", "Stores and serves document files")

Rel(boardMember, adminApp, "Uses")
Rel(staffMember, adminApp, "Uses")
Rel(member, publicApp, "Uses")

Rel(adminApp, docSystem, "Creates, publishes, deletes documents")
Rel(publicApp, docSystem, "Reads published documents")
Rel(docSystem, assetModule, "Stores/retrieves files via DigitalAssetId")

@enduml
