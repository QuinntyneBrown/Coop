@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

skinparam dpi 150
skinparam pageMargin 10

title Document Management - C4 Container Diagram

Person(user, "Coop User", "Board member, staff, member, or visitor")

System_Boundary(docBoundary, "Coop Backend - Document Management") {
  Container(api, "Document API", ".NET 10 / ASP.NET Core", "REST endpoints for document CRUD, publication, and public reads")
  Container(app, "Document Application", ".NET 10 Class Library", "Commands, queries, and in-process notifications")
  Container(domain, "Document Domain", ".NET 10 Class Library", "Aggregate roots, domain events, and business rules")
  Container(infra, "Document Persistence", ".NET 10 Class Library", "EF Core DbContext and configurations")
  ContainerDb(db, "Coop Database", "SQL Server", "Stores documents, by-laws, notices, reports, and stored events")
}

System_Ext(publicApp, "Public Web App", "Reads published documents")
System_Ext(adminApp, "Admin Backend", "Authors and publishes content")

Rel(user, publicApp, "Uses for published content")
Rel(user, adminApp, "Uses for authoring and administration")
Rel(publicApp, api, "Reads published documents", "HTTPS/JSON")
Rel(adminApp, api, "Creates and manages documents", "HTTPS/JSON")
Rel(api, app, "Uses")
Rel(app, domain, "Uses")
Rel(app, infra, "Uses")
Rel(infra, db, "Reads/Writes", "EF Core")

@enduml
