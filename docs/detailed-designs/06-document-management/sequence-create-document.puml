@startuml
skinparam dpi 150
skinparam pageMargin 10
skinparam shadowing false
skinparam defaultFontSize 10
skinparam sequenceMessageAlign center

title Create Document Sequence (Notice / ByLaw / Report)

actor Client
participant "Controller\n(Notice/ByLaw/Report)" as Ctrl
participant "MediatR" as Med
participant "CreateHandler" as Handler
participant "Document\n(AggregateRoot)" as Doc
database "CoopDbContext" as DB
participant "MessageBus" as Bus

Client -> Ctrl : POST /api/{type}
activate Ctrl

Ctrl -> Med : Send(CreateRequest)
activate Med

Med -> Handler : Handle(request)
activate Handler

Handler -> Doc ** : new Document(CreateDocument event)
activate Doc
Doc -> Doc : Apply(CreateDocument)
note right
  Sets DocumentId, Name,
  Body, DigitalAssetId,
  CreatedById, Published
end note
Doc -> Doc : StoreEvent(CreateDocument)
Doc --> Handler : document
deactivate Doc

Handler -> DB : Add(document)
Handler -> DB : SaveChangesAsync()
activate DB
DB --> Handler : saved
deactivate DB

Handler -> Bus : PublishAsync(DocumentCreatedEvent)
activate Bus
Bus --> Handler : published
deactivate Bus

Handler --> Med : CreateResponse
deactivate Handler

Med --> Ctrl : response
deactivate Med

Ctrl --> Client : 200 OK / 201 Created
deactivate Ctrl

@enduml
