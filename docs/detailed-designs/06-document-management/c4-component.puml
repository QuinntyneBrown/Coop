@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

skinparam dpi 150
skinparam pageMargin 10

title Document Management - C4 Component Diagram

Container_Boundary(api, "Document API") {

  Component(docCtrl, "DocumentController", "ApiController", "General document CRUD and pagination")
  Component(noticeCtrl, "NoticeController", "ApiController", "Notice-specific endpoints including published filter")
  Component(bylawCtrl, "ByLawController", "ApiController", "By-law-specific endpoints including published filter")
  Component(reportCtrl, "ReportController", "ApiController", "Report-specific endpoints including published filter")

  Component(createHandler, "Create Handlers", "MediatR IRequestHandler", "Handles CreateNotice, CreateByLaw, CreateReport requests")
  Component(queryHandler, "Query Handlers", "MediatR IRequestHandler", "Handles GetById, GetAll, GetPublished, GetPage requests")
  Component(updateHandler, "Update Handler", "MediatR IRequestHandler", "Handles Update requests (including publish)")
  Component(deleteHandler, "Delete Handler", "MediatR IRequestHandler", "Handles Remove requests")

  Component(validators, "Validators", "FluentValidation", "DocumentValidator, NoticeValidator, ByLawValidator, ReportValidator")
}

Container_Boundary(domainLayer, "Document Domain") {
  Component(docAggregate, "Document Aggregate", "AggregateRoot", "Document, ByLaw, Notice, Report entities and domain events")
}

Container_Boundary(infraLayer, "Document Infrastructure") {
  Component(dbContext, "DocumentDbContext", "EF Core DbContext", "DbSet<Document>, DbSet<Notice>, DbSet<ByLaw>, DbSet<Report>")
}

ComponentDb(db, "SQL Server", "Document tables and StoredEvents")
Component_Ext(messageBus, "MessageBus", "IMessageBus", "Integration event publishing")

Rel(docCtrl, createHandler, "Dispatches via MediatR")
Rel(docCtrl, queryHandler, "Dispatches via MediatR")
Rel(noticeCtrl, createHandler, "Dispatches via MediatR")
Rel(noticeCtrl, queryHandler, "Dispatches via MediatR")
Rel(bylawCtrl, createHandler, "Dispatches via MediatR")
Rel(bylawCtrl, queryHandler, "Dispatches via MediatR")
Rel(reportCtrl, createHandler, "Dispatches via MediatR")
Rel(reportCtrl, queryHandler, "Dispatches via MediatR")

Rel(createHandler, docAggregate, "Creates & applies events")
Rel(updateHandler, docAggregate, "Applies PublishDocument event")
Rel(deleteHandler, docAggregate, "Applies DeleteDocument event")
Rel(createHandler, validators, "Validates input")

Rel(createHandler, dbContext, "Persists entities")
Rel(queryHandler, dbContext, "Queries entities")
Rel(updateHandler, dbContext, "Updates entities")
Rel(deleteHandler, dbContext, "Removes entities")

Rel(dbContext, db, "Reads/Writes")
Rel(createHandler, messageBus, "Publishes DocumentCreatedEvent")
Rel(deleteHandler, messageBus, "Publishes DocumentDeletedEvent")

@enduml
