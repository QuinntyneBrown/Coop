@startuml c4-container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

skinparam dpi 150
skinparam defaultFontSize 11

title Messaging System - C4 Container Diagram

Person(member, "Coop Member", "Sends and receives messages")

System_Boundary(messaging, "Coop Backend - Messaging Module") {
  Container(api, "Messaging API", ".NET / ASP.NET Core", "REST endpoints for conversations and messages")
  Container(app, "Messaging Application", ".NET Class Library", "Commands, queries, and in-process notifications")
  Container(domain, "Messaging Domain", ".NET Class Library", "Conversation and Message entities, domain logic")
  Container(infra, "Messaging Persistence", ".NET Class Library", "MessagingDbContext, EF Core configurations")
  ContainerDb(db, "Coop Database", "SQL Server", "Stores conversations and messages")
}

Rel(member, api, "Uses", "HTTPS/JSON")
Rel(api, app, "Uses")
Rel(app, domain, "Uses")
Rel(app, infra, "Uses")
Rel(infra, db, "Reads/Writes", "EF Core")

@enduml
