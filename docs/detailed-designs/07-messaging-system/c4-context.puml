@startuml c4-context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

skinparam dpi 150
skinparam defaultFontSize 11

title Messaging System - C4 System Context

Person(member, "Coop Member", "Sends and receives messages")

System(messaging, "Messaging Module", "Provides direct messaging between member profiles within conversations")
System_Ext(profile, "Profile Module", "Manages member profiles and identities")
System_Ext(auth, "Identity & Access Module", "Handles authentication and authorization")

Rel(member, messaging, "Sends messages, views conversations", "HTTPS/JSON")
Rel(messaging, profile, "Resolves participant profile IDs", "Internal contract")
Rel(member, auth, "Authenticates", "HTTPS/JWT")
Rel(auth, messaging, "Provides JWT claims for authorization")

@enduml
