@startuml c4-component
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

skinparam dpi 150
skinparam defaultFontSize 11

title Messaging System - C4 Component Diagram

Container_Boundary(api, "Messaging API") {
  Component(convCtrl, "ConversationsController", "ASP.NET Core Controller (.NET 10)", "Handles conversation CRUD and message sending within conversations")
  Component(msgCtrl, "MessagesController", "ASP.NET Core Controller (.NET 10)", "Handles message retrieval, unread queries, and read-status updates")
  Component(appSvc, "MessagingApplicationService", "Application Service", "Coordinates conversation creation, message send, and read operations")
  Component(dispatcher, "InternalNotificationDispatcher", "Application Service", "Dispatches in-process notifications")
}

Container_Boundary(domain, "Messaging Domain") {
  Component(convEntity, "Conversation", "Entity", "Aggregate root: manages participants and messages")
  Component(msgEntity, "Message", "Entity", "Tracks message content, sender, recipient, and read state")
}

Container_Boundary(infra, "Messaging Persistence") {
  Component(dbCtx, "MessagingDbContext", "EF Core DbContext", "Provides DbSets for conversations and messages")
  Component(config, "MessagingConfigurations", "EF Configuration", "Entity type configurations")
}

ComponentDb(db, "Database", "SQL Server", "Persists conversations and messages")

Rel(convCtrl, appSvc, "Uses")
Rel(msgCtrl, appSvc, "Uses")
Rel(appSvc, convEntity, "Creates and updates")
Rel(appSvc, msgEntity, "Marks read")
Rel(appSvc, dbCtx, "Queries/Saves")
Rel(appSvc, dispatcher, "Dispatches notifications")
Rel(dbCtx, db, "Reads/Writes", "EF Core")
Rel(dbCtx, config, "Applies configurations")
Rel(convEntity, msgEntity, "Contains")

@enduml
