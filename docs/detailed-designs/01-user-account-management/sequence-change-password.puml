@startuml sequence-change-password

skinparam defaultFontSize 11
skinparam sequenceMessageAlign center
skinparam shadowing false
skinparam responseMessageBelowArrow true

title Change Password - Sequence Diagram

actor Client
participant "UserController" as UC
participant "IMediator" as M
participant "ChangePasswordHandler" as H
participant "IHttpContextAccessor" as HCA
participant "ICoopDbContext" as DB
participant "User" as U
participant "IPasswordHasher" as PH

Client -> UC : PUT /api/user\n{oldPassword, newPassword,\nconfirmationPassword}
activate UC

UC -> M : Send(ChangePasswordRequest)
activate M

M -> H : Handle(request, ct)
activate H

H -> HCA : HttpContext.User.Identity\n.IsAuthenticated
activate HCA
HCA --> H : true
deactivate HCA

H -> HCA : FindFirst(UserId claim)
activate HCA
HCA --> H : userId
deactivate HCA

H -> DB : Users.SingleAsync(userId)
activate DB
DB --> H : User entity
deactivate DB

H -> U : ChangePassword(oldPw, newPw, hasher)
activate U
U -> PH : HashPassword(salt, oldPassword)
activate PH
PH --> U : old hash
deactivate PH
U -> U : Validate old password matches
U -> PH : HashPassword(salt, newPassword)
activate PH
PH --> U : new hash
deactivate PH
U -> U : Validate new != old
U -> U : Password = newHash
U --> H : User
deactivate U

H -> DB : SaveChangesAsync(ct)
activate DB
DB --> H : saved
deactivate DB

H --> M : ChangePasswordResponse
deactivate H

M --> UC : response
deactivate M

UC --> Client : 200 OK
deactivate UC

@enduml
